# DeskPad Environment Configuration
# Copy this file to .env and adjust values for your setup.

# Port to expose DeskPad on your home server
DESKPAD_PORT=8080

# Environment (production | development)
ENVIRONMENT=production

# Backend
PORT=3001
DB_PATH=/data/deskpad.db

# CORS origins (JSON array)
CORS_ORIGINS=["*"]

# GitHub contributions cache duration in minutes (e.g. 30 for 1/2 hour)
GITHUB_CACHE_MINUTES=60
